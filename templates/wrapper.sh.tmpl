#!/usr/bin/env bash
# Generated by DaGhE Orchestrator
set -euo pipefail

# Calculate dynamic BASE_DIR for the wrapper too
SCRIPT_DIR="$$(cd "$$(dirname "$${BASH_SOURCE[0]}")" && pwd)"
export BASE_DIR="$$(cd "$${SCRIPT_DIR}/../.." && pwd)"

# Logic for locking
LOCK_FILE="$${BASE_DIR}/state/${NAME}.lock"
exec 9>"$$LOCK_FILE"
if ! flock -n 9; then
    echo "[$$({date})] ${NAME}: Already running, skipping."
    exit 0
fi

cd "$${BASE_DIR}/jobs/${NAME}/current"
export PYTHONPATH="src"

# Run with uv
uv run python -m ${ENTRYPOINT} ${PARAMS}
