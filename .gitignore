# Ignore secrets
config/*.env
config/jobs/*.env
config/proxies/*.env
config/cookies/*.txt
!config/*.env.example
!config/jobs/*.env.example
!config/proxies/*.env.example
!config/cookies/*.txt.example

# Ignore job-specific operational payloads and data
jobs/*
!jobs/*/
jobs/*/current/*
jobs/*/data/*
!jobs/*/current/.gitkeep
!jobs/*/data/.gitkeep
!jobs/daghe-check-updates/
!jobs/daghe-check-updates/**

# Ignore generated systemd files
systemd/*.service
systemd/*.timer


# Ignore nested .git folders
**.git/

# Ignore runtime state and uv artifacts
state/*
.python-version
.venv/
__pycache__/
*.pyc

# System logs
logs/*

bin/generated/*.sh
