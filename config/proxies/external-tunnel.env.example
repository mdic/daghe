# DaGhE Proxy Configuration: SSH Tunnel
# UK English: Initialise an ephemeral SOCKS5 tunnel

# The local port to open on the DaGhE VPS
export PROXY_LOCAL_PORT="1080"

# The command to start the tunnel in the background
# -N: Do not execute remote command (just tunnel)
# -D: Dynamic application-level port forwarding (SOCKS)
# -f: We will NOT use -f here because we want Bash to manage the PID
export PROXY_CMD="ssh -o ExitOnForwardFailure=yes -N -D ${PROXY_LOCAL_PORT} user@external-vps-ip"

# The environment variable that Python apps (yt-dlp, httpx) will use
export ALL_PROXY="socks5h://127.0.0.1:${PROXY_LOCAL_PORT}"
export HTTP_PROXY="socks5h://127.0.0.1:${PROXY_LOCAL_PORT}"
export HTTPS_PROXY="socks5h://127.0.0.1:${PROXY_LOCAL_PORT}"
